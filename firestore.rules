rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Users Collection
    // - Users can read and write their own profile
    // - Admins can read and write all profiles
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin(); 
      // Note: In a real app, you might want to prevent users from updating their own 'role' field
      // allow update: if (isOwner(userId) && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role'])) || isAdmin();
      allow delete: if isAdmin();
    }

    // Courses Collection
    // - Public read access
    // - Admin only write access
    match /courses/{courseId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Articles Collection
    // - Public read access
    // - Admin only write access
    match /articles/{articleId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Knowledge Base (for AI Chatbot)
    // - Public read access (so the bot/users can query it)
    // - Admin only write access
    match /knowledge_base/{entryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // System Settings
    // - Public read access (for global config like maintenance mode)
    // - Admin only write access
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Chats Collection
    // - Users can read/write their own chat
    // - Admins can read/write all chats
    match /chats/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();

      match /messages/{messageId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }
  }
}
